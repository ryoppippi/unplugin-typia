{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["esnext", "esnext.asynciterable", "DOM"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"resolveJsonModule": true,
		"strict": true,
		"strictNullChecks": true,
		"declaration": true,
		"outDir": "dist-esm/",
		"sourceMap": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"skipLibCheck": true
	},
	"include": ["src"],
	"exclude": ["dist", "eslint.config.js"]
}
