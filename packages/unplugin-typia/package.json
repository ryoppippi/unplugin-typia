{
	"name": "@ryoppippi/unplugin-typia",
	"type": "module",
	"version": "0.3.8",
	"description": "unplugin for typia",
	"homepage": "https://jsr.io/@ryoppippi/unplugin-typia",
	"repository": "https://github.com/ryoppippi/unplugin-typia",
	"author": "ryoppippi",
	"license": "MIT",
	"keywords": [
		"unplugin",
		"vite",
		"webpack",
		"rollup",
		"next",
		"esbuild",
		"bun",
		"typia",
		"transform"
	],
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"import": "./dist-esm/index.js",
			"default": "./dist-cjs/index.js"
		},
		"./api": {
			"bun": "./src/api.ts",
			"import": "./dist-esm/api.js",
			"default": "./dist-cjs/api.js"
		},
		"./vite": {
			"bun": "./src/vite.ts",
			"import": "./dist-esm/vite.js",
			"default": "./dist-cjs/vite.js"
		},
		"./webpack": {
			"bun": "./src/webpack.ts",
			"import": "./dist-esm/webpack.js",
			"default": "./dist-cjs/webpack.js"
		},
		"./rollup": {
			"bun": "./src/rollup.ts",
			"import": "./dist-esm/rollup.js",
			"default": "./dist-cjs/rollup.js"
		},
		"./esbuild": {
			"bun": "./src/esbuild.ts",
			"import": "./dist-esm/esbuild.js",
			"default": "./dist-cjs/esbuild.js"
		},
		"./next": {
			"bun": "./src/next.ts",
			"import": "./dist-esm/next.js",
			"default": "./dist-cjs/next.js"
		},
		"./rolldown": {
			"bun": "./src/rolldown.ts",
			"import": "./dist-esm/rolldown.js",
			"default": "./dist-cjs/rolldown.js"
		},
		"./farm": {
			"bun": "./src/farm.ts",
			"import": "./dist-esm/farm.js",
			"default": "./dist-cjs/farm.js"
		},
		"./rspack": {
			"bun": "./src/rspack.ts",
			"import": "./dist-esm/rspack.js",
			"default": "./dist-cjs/rspack.js"
		},
		"./bun": {
			"bun": "./src/bun.ts",
			"import": "./dist-esm/bun.js",
			"default": "./dist-cjs/bun.js"
		},
		"./package.json": "./package.json"
	},
	"main": "./dist-cjs/index.js",
	"module": "./dist-esm/index.js",
	"types": "./dist-esm/index.d.ts",
	"files": [
		"README.md",
		"dist-cjs/",
		"dist-esm/",
		"src/"
	],
	"scripts": {
		"lint": "npm run check && eslint . && npx publint",
		"format": "eslint --fix .",
		"build": "rimraf dist-cjs dist-esm && npx tsc -p tsconfig.json && npx tsc -p tsconfig.cjs.json",
		"test": "npm run check && bun test ./test/*.ts",
		"check": "bun tsc --noEmit",
		"publish": "bun x jsr publish",
		"jsr:version": "jq -r '.version' package.json | xargs -I {} jq '.version = \"{}\"' jsr.json > temp.json && mv temp.json jsr.json && npm run format"
	},
	"peerDependencies": {
		"esbuild": "*",
		"rollup": "^3",
		"vite": ">=3",
		"webpack": "^4 || ^5"
	},
	"peerDependenciesMeta": {
		"@nuxt/kit": {
			"optional": true
		},
		"@nuxt/schema": {
			"optional": true
		},
		"esbuild": {
			"optional": true
		},
		"rollup": {
			"optional": true
		},
		"typia": {
			"optional": true
		},
		"vite": {
			"optional": true
		},
		"webpack": {
			"optional": true
		}
	},
	"dependencies": {
		"@rollup/pluginutils": "^5.1.0",
		"consola": "^3.2.3",
		"defu": "^6.1.4",
		"magic-string": "^0.30.10",
		"pkg-types": "^1.1.1",
		"type-fest": "^4.19.0",
		"typescript": "^5.3.2",
		"typia": "^6.0.6",
		"unplugin": "^1.5.1",
		"unstorage": "^1.10.2"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^2.18.0",
		"@std/assert": "npm:@jsr/std__assert",
		"@types/bun": "^1.1.3",
		"@types/node": "^20.10.3",
		"eslint": "^8.55.0",
		"eslint-plugin-format": "^0.1.1",
		"rimraf": "^5.0.7",
		"rollup": "^4.6.1"
	}
}
